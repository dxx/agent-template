APP_HOST=127.0.0.1
APP_PORT=8000

LOG_LEVEL=info
LOG_HANDLERS=["console", "file"]
LOG_FORMAT_TYPE=text
LOG_FILE=logs/app.log

OPENAI_BASE_URL=https://ark.cn-beijing.volces.com/api/coding/v3
OPENAI_API_KEY=${VOLCANO_API_KEY}
OPENAI_MODEL=doubao-seed-2-0-lite-260215
OPENAI_TEMPERATURE=0.7

# Postgres Checkpointer 连接
POSTGRES_CHECKPOINTER_CONN_STR=postgresql://postgres:postgres@localhost:5432/langchain
